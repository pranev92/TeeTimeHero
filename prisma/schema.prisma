generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  passwordHash  String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  bookingRequests BookingRequest[]
  accounts        Account[]
  sessions        Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model GolfCourse {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  websiteUrl        String
  bookingUrl        String?
  timezone          String   @default("America/New_York")
  bookingWindowDays Int      @default(7)
  bookingOpenTime   String   @default("00:20")
  requiresLogin     Boolean  @default(true)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())

  bookingRequests BookingRequest[]

  @@map("golf_courses")
}

// SQLite has no native enum; store as String and validate in app code
// Valid values: SUNDAY MONDAY TUESDAY WEDNESDAY THURSDAY FRIDAY SATURDAY
// Valid job status: PENDING RUNNING SUCCESS FAILED CANCELLED
// Valid log level: INFO WARN ERROR

model BookingRequest {
  id            String  @id @default(cuid())
  userId        String
  courseId      String

  dayOfWeek     String  // DayOfWeek enum value
  preferredTime String
  windowStart   String
  windowEnd     String

  numPlayers    Int     @default(1)
  golferNames   String  @default("[]") // JSON array stored as text

  isActive      Boolean @default(true)
  priority      Int     @default(0)

  siteUsername  String?
  sitePassword  String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  course GolfCourse @relation(fields: [courseId], references: [id])
  jobs   BookingJob[]

  @@map("booking_requests")
}

model BookingJob {
  id            String   @id @default(cuid())
  requestId     String

  scheduledFor  DateTime
  targetDate    DateTime

  status        String   @default("PENDING") // JobStatus enum value
  attempts      Int      @default(0)
  maxAttempts   Int      @default(3)

  confirmedTime  String?
  confirmationId String?
  errorMessage   String?

  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  bullJobId    String?

  request BookingRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  logs    BookingLog[]

  @@index([scheduledFor])
  @@index([status])
  @@map("booking_jobs")
}

model BookingLog {
  id        String   @id @default(cuid())
  jobId     String
  level     String   @default("INFO") // LogLevel enum value
  message   String
  data      String?  // JSON stored as text
  createdAt DateTime @default(now())

  job BookingJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@map("booking_logs")
}
